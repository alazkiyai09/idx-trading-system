{
  "name": "idx-trading-system-e2e",
  "version": "1.0.0",
  "description": "Playwright E2E tests for IDX Trading System",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:api": "playwright test --project=api",
    "test:dashboard": "playwright test --project=dashboard-chromium",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:8501"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
